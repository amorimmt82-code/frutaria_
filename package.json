{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "cross-env NODE_ENV=development tsx server.ts",
    "build": "vite build",
    "preview": "npm run build && cross-env NODE_ENV=production tsx server.ts",
    "start": "cross-env NODE_ENV=production tsx server.ts",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "lint:worker": "tsc --noEmit -p tsconfig.worker.json",
    "worker:dev": "npm run build && wrangler dev",
    "worker:deploy": "npm run build && wrangler deploy",
    "d1:init": "wrangler d1 execute frutaria --remote --file=./migrations/0001_init.sql",
    "d1:init:local": "wrangler d1 execute frutaria --local --file=./migrations/0001_init.sql",
    "d1:seed:gen": "node scripts/migrate-store-json.mjs",
    "d1:seed": "wrangler d1 execute frutaria --remote --file=./migrations/0002_seed.sql",
    "d1:seed:local": "wrangler d1 execute frutaria --local --file=./migrations/0002_seed.sql"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@stripe/react-stripe-js": "^6.3.0",
    "@stripe/stripe-js": "^9.3.1",
    "@tailwindcss/vite": "^4.1.14",
    "@types/nodemailer": "^8.0.0",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "express": "^4.22.1",
    "hono": "^4.12.22",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "nodemailer": "^8.0.7",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.14.2",
    "stripe": "^22.1.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260523.1",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "cross-env": "^7.0.3",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "wrangler": "^4.94.0"
  }
}
